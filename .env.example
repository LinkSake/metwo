# Raindrop.io
# Token: https://app.raindrop.io/settings/integrations
# Collection ID: found in the URL at https://app.raindrop.io/my/{COLLECTION_ID}
# Used by: scripts/sync-raindrop-reads.sh, scripts/sync-lately.sh
RAINDROP_TOKEN=your_token_here
RAINDROP_COLLECTION_ID=your_collection_id

# Bluesky (AT Protocol)
# Identifier: your handle, e.g. linksake.bsky.social
# App password: generate one at https://bsky.app/settings/app-passwords
#   (do NOT use your main account password)
# Used by: scripts/post-to-bluesky.py
BSKY_IDENTIFIER=your_handle.bsky.social
BSKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
